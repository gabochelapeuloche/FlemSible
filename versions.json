{
  "1.35_base": {
    "cluster-name": "k8s",
    "virtual-layer": {
      "base_image": "/home/leg/Documents/Projets/k8s-setup/images/base-node-1.35_base.img",
      "control-plane": {
        "name": "control-plane",
        "count": 1,
        "ports": [
          "22/tcp",
          "6443/tcp",
          "2379:2380/tcp",
          "10249:10260/tcp"
        ],
        "os-version": "noble",
        "cpus": 2,
        "memory": "3G",
        "disk": "15G",
        "cidr": "192.168.0.0/16"
      },
      "worker": {
        "name": "worker",
        "count": 1,
        "ports": [
          "22/tcp",
          "10250/tcp",
          "10256/tcp",
          "30000:32767/tcp",
          "30000:32767/udp"
        ],
        "os-version": "noble",
        "cpus": 2,
        "memory": "3G",
        "disk": "15G"
      }
    },
    "kubernetes": {
      "minor": "1.35",
      "patch": "1.35.0",
      "pkg_version": "1.35.0-1.1",
      "repo_url": "http://pkgs.k8s.io/core:/stable:/v1.35/deb/",
      "release-key": "http://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key"
    },
    "components": {
      "container-runtime": {
        "containerd": {
          "version": "2.2.1",
          "url": "https://github.com/containerd/containerd/releases/download/v2.2.1/containerd-2.2.1-linux-amd64.tar.gz",
          "service-url": "https://raw.githubusercontent.com/containerd/containerd/main/containerd.service"
        }
      },
      "runc": {
        "version": "1.3.4",
        "url": "https://github.com/opencontainers/runc/releases/download/v1.3.4/runc.amd64"
      },
      "cni-plugin": {
        "version": "1.9.0",
        "url": "https://github.com/containernetworking/plugins/releases/download/v1.9.0/cni-plugins-linux-amd64-v1.9.0.tgz"
      },
      "network-plugins": {
        "calico": {
          "version": "v3.28.0",
          "ports": [
            "179/tcp",
            "5473/tcp",
            "4789/udp",
            "51820/udp",
            "51821/udp"
          ],
          "tigera-operator": "https://raw.githubusercontent.com/projectcalico/calico/v3.28.0/manifests/tigera-operator.yaml",
          "crd-url": "https://raw.githubusercontent.com/projectcalico/calico/v3.28.0/manifests/custom-resources.yaml"
        }
      },
      "helm": {
        "version": "3.17.1",
        "url": "https://get.helm.sh/helm-v3.17.1-linux-amd64.tar.gz"
      },
      "harbor": {
        "chart_version": "1.15.1",
        "repo_url": "https://helm.goharbor.io",
        "repo_name": "harbor",
        "chart": "harbor/harbor",
        "namespace": "harbor",
        "release": "harbor"
      },
      "kube-prometheus-stack": {
        "chart_version": "67.9.0",
        "repo_url": "https://prometheus-community.github.io/helm-charts",
        "repo_name": "prometheus-community",
        "chart": "prometheus-community/kube-prometheus-stack",
        "namespace": "monitoring",
        "release": "prometheus",
        "resources": {
          "alertmanager": { "request": "64Mi",  "limit": "128Mi" },
          "prometheus":   { "request": "256Mi", "limit": "768Mi" },
          "grafana":      { "request": "64Mi",  "limit": "128Mi" }
        }
      },
      "argocd": {
        "chart_version": "7.7.6",
        "repo_url": "https://argoproj.github.io/argo-helm",
        "repo_name": "argo",
        "chart": "argo/argo-cd",
        "namespace": "argocd",
        "release": "argocd"
      },
      "istio": {
        "version": "1.24.2",
        "repo_url": "https://istio-release.storage.googleapis.com/charts",
        "repo_name": "istio",
        "namespace": "istio-system"
      },
      "envoy-gateway": {
        "chart_version": "1.2.1",
        "repo_url": "oci://docker.io/envoyproxy/gateway-helm",
        "namespace": "envoy-gateway-system",
        "release": "eg"
      }
    },
    "tools": {
      "helm": true,
      "prometheus": true,
      "istio": true,
      "argocd": true,
      "envoy": true,
      "harbor": true
    }
  }
}
