{
  "1.35": {
    "required_operations": {
      "vms": [
        "--provide-vm",
        "--check-ram",
        "--check-cpu",
        "--check-hostname-unicity",
        "--check-mac_address-unicity",
        "--check-product_uuid-unicity",
        "--check-connection",
        "--check-os-version"
      ],
      "control-plane": [
        "--set-ports",
        "--check-ports",
        "--swap-off",
        "--ipv4-forwarding",
        "--iptables-setup",
        "--install-container-runtime",
        "--install-runc",
        "--install-cni-plugin",
        "--configure-systemd",
        "--install-kubeadm",
        "--configure-crictl",
        "--init-control-plane",
        "--install-calico"
      ],
      "worker": [
        "--set-ports",
        "--check-ports",
        "--swap-off",
        "--ipv4-forwarding",
        "--iptables-setup",
        "--install-container-runtime",
        "--install-runc",
        "--install-cni-plugin",
        "--configure-systemd",
        "--install-kubeadm",
        "--configure-crictl",
        "--join-worker"
      ]
    },
    "virtual-layer": {
      "control-plane": {
        "name": "control-plane",
        "count": 1,
        "ports": [
          "22/tcp",
          "6443/tcp",
          "2379:2380/tcp",
          "10249:10260/tcp"
        ],
        "os-version":"noble",
        "cpus": 2,
        "memory": "2G",
        "disk": "15G",
        "cidr": "192.168.0.0/16"
      },
      "worker": {
        "name": "worker",
        "count": 2,
        "ports": [
          "22/tcp",
          "10250/tcp",
          "10256/tcp",
          "30000:32767/tcp",
          "30000:32767/udp"
        ],
        "os_version":"noble",
        "cpus": 2,
        "memory":"2G",
        "disk":"15G"
      }
    },
    "kubernetes": {
      "minor": "1.35",
      "patch": "1.35.0",
      "pkg_version": "1.35.0-1.1",
      "repo_url": "http://pkgs.k8s.io/core:/stable:/v1.35/deb/"
    },
    "components": {
      "container-runtime": {
        "containerd" : {
          "version": "2.2.1",
          "url": "https://github.com/containerd/containerd/releases/download/v2.2.1/containerd-2.2.1-linux-amd64.tar.gz"
        }
      },
      "runc": {
        "version": "1.3.4",
        "url": "https://github.com/opencontainers/runc/releases/download/v1.3.4/runc.amd64"
      },
      "cni-plugin": {
        "version": "1.9.0",
        "url": "https://github.com/containernetworking/plugins/releases/download/v1.9.0/cni-plugins-linux-amd64-v1.9.0.tgz" 
      },
      "network-plugins": {
        "calico": {
          "version":"v3.28.0",
          "ports": [
            "179/tcp",
            "5473/tcp"
          ],
          "tigera-operator": "kubectl create -f https://raw.githubusercontent.com/projectcalico/calico/v3.28.0/manifests/tigera-operator.yaml",
          "crd-url": "https://raw.githubusercontent.com/projectcalico/calico/v3.28.0/manifests/custom-resources.yaml"
        }

      }
    }
  }
}